# Anamnesa artifacts — regenerable, don't commit
index/lance/
index/bm25.pkl
# All crawled PDFs — 264MB across 79 files organized by source_type
# subdirs (pnpk/, ppk_fktp/). They are Pasal 42 public domain and MAY
# be committed, but default is out-of-git because GitHub has a 1GB
# soft limit and the crawler can re-fetch from source. Add specific
# PDFs with `git add -f catalog/cache/pnpk/foo.pdf` if needed.
catalog/cache/
# Runtime lock file from tools/manifest_append.py concurrent writers.
catalog/manifest.json.lock

