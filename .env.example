# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-...

# Model IDs (per CLAUDE.md routing rules)
ANAMNESA_MODEL_NORMALIZER=claude-haiku-4-5-20251001
ANAMNESA_MODEL_INGESTER=claude-sonnet-4-6
ANAMNESA_MODEL_DRAFTER=claude-opus-4-7
ANAMNESA_MODEL_VERIFIER=claude-opus-4-7

# Thinking budgets
ANAMNESA_DRAFTER_THINKING_BUDGET=8000
ANAMNESA_VERIFIER_THINKING_BUDGET=12000

# --- Retrieval / MCP ---
ANAMNESA_MCP_URL=http://127.0.0.1:8765
LANCE_DB_PATH=./index/lance
BM25_INDEX_PATH=./index/bm25.pkl

# --- Embeddings ---
EMBEDDINGS_PROVIDER=local              # local | voyage
BGE_M3_MODEL=BAAI/bge-m3
VOYAGE_API_KEY=

# --- Per-query budget guardrails (hard stops) ---
ANAMNESA_MAX_RETRIEVAL_ATTEMPTS=3
ANAMNESA_MAX_DRAFTER_CALLS=3
ANAMNESA_MAX_VERIFIER_CALLS=2
ANAMNESA_MAX_TOTAL_TOKENS_PER_QUERY=150000
ANAMNESA_MAX_WALL_CLOCK_SECONDS=30

# --- Logging / observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json                        # json | console
SENTRY_DSN=

# --- Deployment ---
ANAMNESA_PUBLIC_ORIGIN=https://anamnesa.kudaliar.id
