# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-...

# Model IDs (per CLAUDE.md routing rules)
ANAMNESA_MODEL_NORMALIZER=claude-haiku-4-5-20251001
ANAMNESA_MODEL_INGESTER=claude-sonnet-4-6
ANAMNESA_MODEL_DRAFTER=claude-opus-4-7
ANAMNESA_MODEL_VERIFIER=claude-opus-4-7

# Thinking effort: low | medium | high | xhigh. `high` is the prod
# default — benchmarked ~42% faster than xhigh at no loss of
# citation quality on the 23-query eval.
ANAMNESA_DRAFTER_EFFORT=high
ANAMNESA_VERIFIER_EFFORT=high

# Thinking token budgets (adaptive thinking counts against these).
ANAMNESA_DRAFTER_THINKING_BUDGET=8000
ANAMNESA_VERIFIER_THINKING_BUDGET=12000

# --- Retrieval / MCP ---
ANAMNESA_MCP_URL=http://127.0.0.1:8765
ANAMNESA_EMBEDDER=bge-m3               # bge-m3 | hash (hash = fast dev stub)
LANCE_DB_PATH=./index/lance
BM25_INDEX_PATH=./index/bm25.pkl

# --- Embeddings ---
EMBEDDINGS_PROVIDER=local              # local | voyage
BGE_M3_MODEL=BAAI/bge-m3
VOYAGE_API_KEY=

# --- Answer cache ---
# 24h SQLite cache keyed on the canonicalized raw user query. On a
# hit the Orchestrator skips Normalizer + Retriever + Drafter +
# Verifier entirely — cost $0, latency ~0 s.
ANAMNESA_CACHE_PATH=catalog/cache/answers.db
ANAMNESA_CACHE_TTL_S=86400
# ANAMNESA_CACHE_DISABLED=1            # uncomment to hard-disable the cache

# --- Feedback store ---
# SQLite rows for 👍 / 👎 taps. Surfaced at /admin/feedback.
ANAMNESA_FEEDBACK_PATH=catalog/cache/feedback.db

# --- Per-query budget guardrails (hard stops) ---
ANAMNESA_MAX_RETRIEVAL_ATTEMPTS=3
ANAMNESA_MAX_DRAFTER_CALLS=3
ANAMNESA_MAX_VERIFIER_CALLS=2
ANAMNESA_MAX_TOTAL_TOKENS_PER_QUERY=150000
# Real Opus calls on xhigh can run 3-4 min; leave 450 for prod.
# 30 s is only safe with scripted-fake agents (tests / dev).
ANAMNESA_MAX_WALL_CLOCK_SECONDS=450

# --- Logging / observability ---
LOG_LEVEL=INFO
LOG_FORMAT=json                        # json | console
SENTRY_DSN=

# --- Deployment ---
ANAMNESA_PUBLIC_ORIGIN=https://anamnesa.kudaliar.id
